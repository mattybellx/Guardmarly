// Golden Corpus: Prototype Pollution (CWE-1321) — JavaScript
// MUST NOT trigger the rule

// Safe: Uses Object.freeze to prevent prototype modification
const DEFAULT_CONFIG = Object.freeze({
    theme: "dark",
    language: "en",
});

function getConfig(overrides) {
    // Safe: creates new object without prototype, manually copies only known keys
    const safe = Object.create(null);
    const allowed = new Set(["theme", "language"]);
    for (const key of Object.keys(overrides || {})) {
        if (allowed.has(key)) {
            safe[key] = overrides[key];
        }
    }
    return Object.assign({}, DEFAULT_CONFIG, safe);
}

app.get('/config', (req, res) => {
    const config = getConfig(req.query);
    res.json(config);
});
