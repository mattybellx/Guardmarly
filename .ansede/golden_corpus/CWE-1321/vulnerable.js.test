// Golden Corpus: Prototype Pollution (CWE-1321) — JavaScript
// MUST trigger the rule

function merge(target, source) {
    for (let key in source) {
        if (typeof source[key] === 'object') {
            target[key] = merge(target[key] || {}, source[key]);
        } else {
            target[key] = source[key];
        }
    }
    return target;
}

// Vulnerable: no __proto__ check
app.post('/update', (req, res) => {
    const config = merge({}, req.body);
    res.json(config);
});

// Direct prototype access via bracket notation
app.get('/set', (req, res) => {
    const obj = {};
    const key = req.query.key;
    const value = req.query.value;
    obj[key] = value;  // key could be "__proto__"
    res.json(obj);
});
