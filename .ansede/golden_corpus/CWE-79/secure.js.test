// Golden Corpus: XSS (CWE-79) — JavaScript
// MUST NOT trigger the rule

const express = require('express');
const app = express();

// Safe: template engine with auto-escaping configured
app.set('view engine', 'ejs');
app.set('views', './views');

app.get('/page', (req, res) => {
    // Safe: renders via template engine that auto-escapes output
    res.render('page', { title: 'Welcome' });
});

app.get('/api/status', (req, res) => {
    // Safe: JSON response, not HTML
    res.json({ status: 'ok', uptime: process.uptime() });
});
