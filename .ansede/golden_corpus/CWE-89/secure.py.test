# Golden Corpus: SQL Injection (CWE-89) — Python
# MUST NOT trigger the rule

# Safe: all queries use parameterized placeholders (?).
# No string concatenation, f-strings, or variable interpolation in SQL.

def get_user(cursor, user_id: int):
    cursor.execute("SELECT * FROM users WHERE id = ?", (user_id,))
    return cursor.fetchone()

def search_products(cursor, pattern: str):
    cursor.execute("SELECT * FROM products WHERE name LIKE ?", (pattern,))
    return cursor.fetchall()

def update_email(cursor, user_id: int, email: str):
    cursor.execute("UPDATE users SET email = ? WHERE id = ?", (email, user_id))
