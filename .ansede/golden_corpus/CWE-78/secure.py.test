# Golden Corpus: Command Injection (CWE-78)
# MUST NOT trigger the rule

import subprocess

def run_command():
    # Fixed command, no user input — safe
    subprocess.call(["ls", "-la", "/tmp"], shell=False)

def ping_host(host):
    # Argument list — safe
    subprocess.run(["ping", "-c", "1", host], shell=False, check=True)

def exec_cmd():
    # Using safe wrapper
    subprocess.run(["echo", "hello"], shell=False)
