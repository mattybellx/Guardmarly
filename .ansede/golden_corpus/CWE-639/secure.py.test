# Golden Corpus: IDOR / BOLA (CWE-639) — Python
# MUST NOT trigger the rule

# Safe: always scopes queries to the current authenticated user.
# No direct object references — all access goes through session identity.

def get_user_invoices(session_user_id: int) -> list:
    """Safe: queries scoped to the authenticated user only."""
    return db.execute(
        "SELECT * FROM invoices WHERE owner_id = ?",
        (session_user_id,)
    )

def get_document(session_user_id: int, doc_id: int) -> dict | None:
    """Safe: ownership verified before returning data."""
    doc = db.execute(
        "SELECT * FROM documents WHERE id = ? AND owner_id = ?",
        (doc_id, session_user_id)
    )
    return doc[0] if doc else None
