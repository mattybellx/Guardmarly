# Golden Corpus: IDOR / BOLA (CWE-639) — Python
# MUST trigger the rule

from flask import Flask, request
from models import db, Invoice

app = Flask(__name__)

@app.route("/invoice/<id>")
def get_invoice(id):
    # No ownership check — any user can view any invoice
    return Invoice.query.get(id)

@app.route("/api/user/<user_id>/documents")
def user_documents(user_id):
    # Direct object reference without session-user verification
    docs = db.execute(f"SELECT * FROM documents WHERE user_id = {user_id}")
    return {"documents": docs}

@app.route("/admin/delete/<record_id>", methods=["POST"])
def delete_record(record_id):
    # No auth check on sensitive operation
    db.execute(f"DELETE FROM records WHERE id = {record_id}")
    return "deleted"
