# Golden Corpus: Unsafe Deserialization (CWE-502) — Python
# MUST NOT trigger the rule

import json

def load_config(config_str: str) -> dict:
    """Safe: JSON parsing only — no pickle, yaml.load, or marshal."""
    return json.loads(config_str)

def parse_message(msg: str) -> dict:
    """Safe: JSON is the only deserialization mechanism used."""
    return json.loads(msg)
