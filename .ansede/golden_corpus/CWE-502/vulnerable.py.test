# Golden Corpus: Unsafe Deserialization (CWE-502) — Python
# MUST trigger the rule

import pickle
import yaml
import marshal

def load_user_data(data):
    return pickle.loads(data)  # Unsafe deserialization

def load_config(yaml_str):
    return yaml.load(yaml_str)  # yaml.load without SafeLoader

def restore_state(blob):
    return marshal.loads(blob)  # Unsafe marshal
