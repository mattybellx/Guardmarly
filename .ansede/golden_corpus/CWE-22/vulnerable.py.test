# Golden Corpus: Path Traversal (CWE-22) — Python
# MUST trigger the rule

import os
from flask import Flask, request, send_file

app = Flask(__name__)

@app.route("/download")
def download():
    filename = request.args.get("file", "")
    path = os.path.join("/var/www/uploads", filename)
    return send_file(path)  # No validation — path traversal

@app.route("/read")
def read_file():
    name = request.args.get("name", "")
    with open(f"/etc/configs/{name}") as f:  # User in path
        return f.read()

@app.route("/view")
def view():
    template = request.args.get("template", "index")
    # Jinja2 without sandbox — SSTI via path traversal
    with open(f"templates/{template}.html") as f:
        return f.read()
