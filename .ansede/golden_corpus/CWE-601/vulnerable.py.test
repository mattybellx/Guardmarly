# Golden Corpus: Open Redirect (CWE-601) — Python
# MUST trigger the rule

from flask import Flask, request, redirect

app = Flask(__name__)

@app.route("/redirect")
def do_redirect():
    url = request.args.get("url", "/")
    return redirect(url)  # User-controlled redirect target

@app.route("/goto")
def goto():
    next_page = request.args.get("next")
    # No validation on redirect target
    return redirect(next_page or "/dashboard")

@app.route("/login")
def login():
    redirect_to = request.args.get("redirect_to", "/")
    # Common pattern: redirect after login without validation
    return redirect(redirect_to)
