// Ansede Static — Jenkins Pipeline Template
// Copy this to your Jenkinsfile or include as a shared library step.
//
// Prerequisites: Python 3.9+ available on the Jenkins agent
// SARIF results are archived as build artifacts.
//
// Pipeline view of findings requires the "Warnings Next Generation" plugin:
//   https://plugins.jenkins.io/warnings-ng/

pipeline {
    agent any

    parameters {
        string(name: 'ANSEDE_PATH',           defaultValue: '.', description: 'Path to scan')
        string(name: 'ANSEDE_FAIL_ON',        defaultValue: 'high', description: 'Fail build on findings at this severity or above (critical/high/medium/low/never)')
        string(name: 'ANSEDE_MIN_CONFIDENCE', defaultValue: '0.65', description: 'Minimum confidence threshold (0.0-1.0)')
        string(name: 'ANSEDE_EXCLUDE',        defaultValue: '',      description: 'Comma-separated paths to exclude')
    }

    stages {
        stage('Install Ansede Static') {
            steps {
                sh 'pip install ansede-static --quiet'
                sh 'ansede-static --version'
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    def excludeFlag = params.ANSEDE_EXCLUDE ? "--exclude ${params.ANSEDE_EXCLUDE}" : ""
                    sh """
                        ansede-static ${params.ANSEDE_PATH} \\
                            --format sarif \\
                            --output ansede.sarif \\
                            --fail-on ${params.ANSEDE_FAIL_ON} \\
                            --min-confidence ${params.ANSEDE_MIN_CONFIDENCE} \\
                            ${excludeFlag}
                    """
                }
            }
            post {
                always {
                    // Archive SARIF report
                    archiveArtifacts artifacts: 'ansede.sarif', allowEmptyArchive: true

                    // Parse with Warnings Next Generation plugin (if installed)
                    script {
                        try {
                            recordIssues(
                                enabledForFailure: true,
                                tool: sarif(pattern: 'ansede.sarif', id: 'ansede-static', name: 'Ansede Security Scan'),
                                qualityGates: [[
                                    threshold: 1,
                                    type: 'TOTAL_HIGH',
                                    unstable: false
                                ]]
                            )
                        } catch (Exception e) {
                            echo "Warnings Next Generation plugin not available: ${e.message}"
                            echo "Install it at: https://plugins.jenkins.io/warnings-ng/"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Ansede Static scan complete. Report: ${env.BUILD_URL}artifact/ansede.sarif"
        }
    }
}
