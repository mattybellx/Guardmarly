{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mattybellx/Guardmarly/schemas/rule_schema.json",
  "title": "Guardmarly Custom Rule Schema",
  "description": "Schema for Guardmarly custom/community YAML rules.",
  "oneOf": [
    {
      "type": "object",
      "required": ["rules"],
      "properties": {
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/rule" }
        }
      },
      "additionalProperties": true
    },
    { "$ref": "#/$defs/rule" }
  ],
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "cwe": {
          "type": "string",
          "pattern": "^CWE-[0-9]+$"
        },
        "language": { "type": "string" },
        "languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pattern": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "regex": { "type": "string" },
                "route_decorator": { "type": "string" },
                "missing_decorator": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "sink": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "array", "items": { "type": "string" } }
                  ]
                }
              },
              "additionalProperties": true
            }
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
